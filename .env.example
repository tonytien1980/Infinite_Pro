POSTGRES_DB=ai_advisory_os
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ai_advisory_os
UPLOAD_DIR=/app/storage/uploads
DERIVED_DIR=/app/storage/derived
RELEASE_DIR=/app/storage/releases
MODEL_PROVIDER=mock
MODEL_PROVIDER_API_KEY=
MODEL_PROVIDER_MODEL=
MODEL_PROVIDER_BASE_URL=
MODEL_PROVIDER_TIMEOUT_SECONDS=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
MODEL_PROVIDER_FAILURE_MODE=
